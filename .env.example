# Copy this file to ".env" in this folder (patient-app). Do not commit ".env".
#
# Your Node backend must be reachable from the phone (same Wi-Fi for real devices).
# No trailing slash on the URL.
#
# Example (replace with your PC's LAN IP):
# EXPO_PUBLIC_API_URL=http://192.168.1.100:5000/api
#
# Expo Go on the same LAN often auto-detects the IP; this override is required for
# tunnel mode, VPN, or when auto-detection fails.

EXPO_PUBLIC_API_URL=
